{
  "manifest_version": 3,
  "name": "Excalisave",
  "version": "2.3.0",
  "short_name": "Excalisave",
  "description": "Save your excalidraw drawings.",
  "icons": {
    "16": "assets/icons/16.png",
    "48": "assets/icons/48.png",
    "128": "assets/icons/128.png"
  },
  "homepage_url": "https://github.com/david-vos/excalisave",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "unlimitedStorage"
  ],
  "__chrome|firefox__author": "david-vos (fork of atharvakadlag/excalisave)",
  "__opera__developer": {
    "name": "david-vos"
  },
  "__firefox|prod__browser_specific_settings": {
    "gecko": {
      "id": "excalisave-fork@dvos.me",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "__chrome__minimum_chrome_version": "88",
  "__opera__minimum_opera_version": "36",
  "action": {
    "default_title": "Excalisave",
    "default_popup": "popup.html"
  },
  "__chrome|opera__options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      }
    }
  },
  "__chrome|opera__background": {
    "service_worker": "js/background.bundle.js"
  },
  "__firefox__background": {
    "scripts": [
      "js/background.bundle.js"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "host_permissions": [
    "https://excalidraw.com/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://excalidraw.com/*"
      ],
      "js": [
        "libs/react.production.min.js",
        "libs/react-dom.production.min.js",
        "js/content-scripts/listenDrawingUpdates.bundle.js"
      ],
      "css": [
        "css/content-scripts/listenDrawingUpdates.css"
      ]
    }
  ]
}